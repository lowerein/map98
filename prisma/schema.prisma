generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // url / directUrl are injected at runtime via prisma.config.ts + the driver adapter (lib/prisma.ts)
}

// ------------------------------------------------------
// 1. Google Auth & User Management
// ------------------------------------------------------
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  role      Role       @default(USER)
  status    UserStatus @default(INACTIVE)
  createdAt DateTime   @default(now())

  accounts Account[]
  sessions Session[]

  places          Place[]
  itineraries     Itinerary[]
  itineraryShares ItineraryShare[]
  placeShares     PlaceShare[]
}

enum Role {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  INACTIVE
  BANNED
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ------------------------------------------------------
// 2. Places (denormalised to match the planner UI shape)
// ------------------------------------------------------
model Place {
  id            String      @id @default(cuid())
  googlePlaceId String?
  name          String
  lat           Float
  lng           Float
  address       String?
  phoneNumber   String?
  openingHours  String[]    @default([])
  country       String?
  province      String?
  googleMapsUrl String?
  color         String?  @default("#2563eb")
  customFields  Json?       @default("{}")
  status        PlaceStatus @default(APPROVED)

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  shares PlaceShare[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

enum PlaceStatus {
  PENDING
  APPROVED
  REJECTED
}

// ------------------------------------------------------
// 3. Itineraries (schedules) — JSON day/calendar blobs
// ------------------------------------------------------
model Itinerary {
  id        String  @id @default(cuid())
  name      String
  startDate String?
  endDate   String?
  // Denormalised planner state (weekly days + FullCalendar events)
  scheduleDays   Json @default("[]")
  calendarEvents Json @default("[]")

  ownerId String
  owner   User   @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  shares ItineraryShare[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([ownerId])
}

// ------------------------------------------------------
// 4. Sharing & collaboration (Viewer / Editor)
// ------------------------------------------------------
enum ShareRole {
  VIEWER
  EDITOR
}

model ItineraryShare {
  id          String    @id @default(cuid())
  itineraryId String
  itinerary   Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role        ShareRole @default(EDITOR)
  createdAt   DateTime  @default(now())

  @@unique([itineraryId, userId])
  @@index([userId])
}

model PlaceShare {
  id        String    @id @default(cuid())
  placeId   String
  place     Place     @relation(fields: [placeId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      ShareRole @default(EDITOR)
  createdAt DateTime  @default(now())

  @@unique([placeId, userId])
  @@index([userId])
}

// ------------------------------------------------------
// 5. Admin: global custom fields & system settings
// ------------------------------------------------------
model GlobalField {
  id              String    @id @default(cuid())
  key             String    @unique
  label           String
  type            FieldType @default(TEXT)
  isRequired      Boolean   @default(false)
  isActive        Boolean   @default(true)
  isSystemDefault Boolean   @default(false)
  order           Int       @default(0)
  createdAt       DateTime  @default(now())
}

enum FieldType {
  TEXT
  TEXTAREA  
  NUMBER
  CHECKBOX
  FILE
  IMAGE
  DATE
}

model SystemSetting {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt
}
